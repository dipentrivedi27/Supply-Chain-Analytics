{
  "name": "Custom Theme",
  "dataColors": [
    "#199f27",
    "#e9df62",
    "#77ca42",
    "#127378",
    "#cc8e7a"
  ],
  "foreground": "#111827",
  "background": "#e8f5e9",
  "foregroundNeutralSecondary": "#6b7280",
  "backgroundLight": "#d1ecd4",
  "foregroundNeutralTertiary": "#6b7280",
  "backgroundNeutral": "#f4faf4",
  "tableAccent": "#199f27",
  "maximum": "#77ca42",
  "center": "#e9df62",
  "minimum": "#199f27",
  "bad": "#199f27",
  "neutral": "#e9df62",
  "good": "#77ca42",
  "textClasses": {
    "callout": {
      "color": "#111827",
      "fontFace": "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
    },
    "title": {
      "color": "#111827",
      "fontFace": "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
    },
    "header": {
      "color": "#111827",
      "fontFace": "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
    },
    "label": {
      "color": "#111827",
      "fontFace": "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#f4faf4"
              }
            }
          }
        ],
        "border": [
          {
            "color": {
              "solid": {
                "color": "#f4faf4"
              }
            },
            "show": true,
            "radius": 8
          }
        ],
        "visualHeader": [
          {
            "background": {
              "solid": {
                "color": "#f4faf4"
              }
            },
            "border": {
              "solid": {
                "color": "#f4faf4"
              }
            }
          }
        ]
      }
    },
    "page": {
      "*": {
        "outspace": [
          {
            "color": {
              "solid": {
                "color": "#d1ecd4"
              }
            }
          }
        ],
        "outspacePane": [
          {
            "backgroundColor": {
              "solid": {
                "color": "#ffffff"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#000000"
              }
            }
          }
        ],
        "background": [
          {
            "color": {
              "solid": {
                "color": "#e8f5e9"
              }
            },
            "transparency": 0
          }
        ],
        "filterCard": [
          {
            "$id": "Applied",
            "backgroundColor": {
              "solid": {
                "color": "#ececec"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#000000"
              }
            },
            "transparency": 0
          },
          {
            "$id": "Available",
            "backgroundColor": {
              "solid": {
                "color": "#ffffff"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#000000"
              }
            },
            "transparency": 0
          }
        ]
      }
    }
  }
}